#!/bin/sh
set -e

# Automatically added by dh_installsystemduser/13.24.1ubuntu2
if [ "$1" = "configure" ] || [ "$1" = "abort-upgrade" ] || [ "$1" = "abort-deconfigure" ] || [ "$1" = "abort-remove" ] ; then
	if [ -z "$DPKG_ROOT" ] ; then
		# The following line should be removed in trixie or trixie+1
		deb-systemd-helper --user unmask 'wallet-cli-daemon.service' >/dev/null || true

		# was-enabled defaults to true, so new installations run enable.
		if deb-systemd-helper --quiet --user was-enabled 'wallet-cli-daemon.service' ; then
			# Enables the unit on first installation, creates new
			# symlinks on upgrades if the unit file has changed.
			deb-systemd-helper --user enable 'wallet-cli-daemon.service' >/dev/null || true
		else
			# Update the statefile to add new symlinks (if any), which need to be
			# cleaned up on purge. Also remove old symlinks.
			deb-systemd-helper --user update-state 'wallet-cli-daemon.service' >/dev/null || true
		fi
	fi
fi
# End automatically added section
# Automatically added by dh_installsystemduser/13.24.1ubuntu2
if [ "$1" = "configure" ] || [ "$1" = "abort-upgrade" ] || [ "$1" = "abort-deconfigure" ] || [ "$1" = "abort-remove" ] ; then
	if [ -z "$DPKG_ROOT" ] ; then
		# The following line should be removed in trixie or trixie+1
		deb-systemd-helper --user unmask 'wallet-cli-daemon.socket' >/dev/null || true

		# was-enabled defaults to true, so new installations run enable.
		if deb-systemd-helper --quiet --user was-enabled 'wallet-cli-daemon.socket' ; then
			# Enables the unit on first installation, creates new
			# symlinks on upgrades if the unit file has changed.
			deb-systemd-helper --user enable 'wallet-cli-daemon.socket' >/dev/null || true
		else
			# Update the statefile to add new symlinks (if any), which need to be
			# cleaned up on purge. Also remove old symlinks.
			deb-systemd-helper --user update-state 'wallet-cli-daemon.socket' >/dev/null || true
		fi
	fi
fi
# End automatically added section


case "$1" in
    configure)
        # Try to enable and start the user service if we can detect the user
        if [ -n "$SUDO_USER" ] && [ "$SUDO_USER" != "root" ]; then
            echo "Enabling wallet-cli-daemon for user $SUDO_USER..."
            if su - "$SUDO_USER" -c "systemctl --user daemon-reload && systemctl --user enable wallet-cli-daemon.service" 2>/dev/null; then
                echo "  Service enabled. Start with: systemctl --user start wallet-cli-daemon"
            else
                echo "  Could not auto-enable. Please run manually:"
                echo "    systemctl --user enable --now wallet-cli-daemon.service"
            fi
        else
            echo ""
            echo "wallet-cli-daemon systemd user service installed."
            echo ""
            echo "To enable and start the daemon for your user:"
            echo "  systemctl --user daemon-reload"
            echo "  systemctl --user enable --now wallet-cli-daemon.service"
            echo ""
        fi
        ;;
esac

exit 0
